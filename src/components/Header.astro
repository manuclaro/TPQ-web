  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <Logo />
    <nav class="flex gap-6 text-sm text-slate-300">
      <a href="#servicios" class="hover:text-emerald-400">Servicios</a>
      <a href="#contacto" class="hover:text-emerald-400">Contacto</a>
    </nav>
  </div>
