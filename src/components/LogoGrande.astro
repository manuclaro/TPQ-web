---
// src/components/LogoGrande.astro
---
<div class="flex flex-col items-center justify-center mb-8 group">
  <div class="w-24 h-24 md:w-32 md:h-32 bg-emerald-500 rounded-2xl flex items-center justify-center shadow-2xl shadow-emerald-500/20 group-hover:scale-105 transition-transform duration-500">
    <div class="flex items-baseline group-hover:tracking-tighter transition-all duration-500">
      <span class="text-slate-950 text-4xl md:text-5xl font-black italic tracking-tighter">T</span>
      <span class="text-slate-950 text-4xl md:text-5xl font-black italic tracking-tighter -ml-1">P</span>
      <span class="text-slate-950 text-4xl md:text-5xl font-black italic tracking-tighter -ml-1">Q</span>
    </div>
  </div>
  
  <div class="mt-6 text-center">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-white">
      TPQ <span class="text-emerald-400">Solutions</span>
    </h2>
    <p class="text-xs md:text-sm tracking-[0.3em] uppercase text-slate-500 mt-2 font-semibold">
      Soluciones tecnológicas
    </p>
  </div>
</div>