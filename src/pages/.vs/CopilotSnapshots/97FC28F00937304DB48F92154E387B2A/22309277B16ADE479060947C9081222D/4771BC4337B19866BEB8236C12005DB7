<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6 py-24">
  <!-- Ambient blobs -->
  <div class="absolute top-[-80px] left-[-80px] w-96 h-96 bg-emerald-500 rounded-full filter blur-[160px] opacity-10 pointer-events-none"></div>
  <div class="absolute bottom-[-80px] right-[-80px] w-96 h-96 bg-blue-600 rounded-full filter blur-[160px] opacity-10 pointer-events-none"></div>

  <div class="relative z-10 text-center max-w-4xl mx-auto">
