  </g>
  
  <g fill="currentColor">
    <circle cx="15" cy="20" r="4" />
    <circle cx="55" cy="20" r="4" />
    
    <circle cx="35" cy="25" r="2.5" />
    <circle cx="35" cy="32" r="2.5" />
    <circle cx="35" cy="40" r="2.5" />
    
    <circle cx="65" cy="55" r="2" />
    <circle cx="78" cy="45" r="2.2" />
    <circle cx="78" cy="65" r="2.2" />
    <circle cx="90" cy="35" r="2.8" />
    <circle cx="90" cy="55" r="2.8" />
    <circle cx="90" cy="75" r="2.8" />
  </g>

  <circle cx="35" cy="85" r="6" fill="currentColor" class="animate-pulse text-white opacity-80" />
